# Raven v3 to v4 Migration Database Configuration
# Copy this file to .env and update with your actual credentials

# Source Database (Raven v3)
SOURCE_DB_HOST=dev-db-dmz02.nilu.no
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=ravendb
SOURCE_DB_USER=ravendb
SOURCE_DB_PASSWORD=your_password_here

# Target Database (Raven v4)
TARGET_DB_HOST=dev-db-dmz02.nilu.no
TARGET_DB_PORT=5432
TARGET_DB_NAME=ravendb4
TARGET_DB_USER=ravendb4
TARGET_DB_PASSWORD=your_password_here
